{
  "name": "@tylerjnewman/kb",
  "version": "0.1.1",
  "description": "Agent-first CLI for local markdown knowledge bases.",
  "keywords": [
    "knowledge-base",
    "markdown",
    "cli",
    "agent",
    "basic-memory"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TylerJNewman/kb.git"
  },
  "homepage": "https://github.com/TylerJNewman/kb#readme",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": "1.3.10"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "kb": "bin/kb"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit --project tsconfig.json",
    "verify": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
